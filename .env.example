# ─────────────────────────────────────────────────────────────
# NZAMBE COIFFURE — Variables d'environnement
# 1. Copiez ce fichier : cp .env.example .env
# 2. Remplissez chaque valeur
# 3. Sur Hostinger : collez ces variables dans hPanel > Node.js > Env Variables
# ─────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/nzambe-coiffure?retryWrites=true&w=majority

# JWT
JWT_SECRET=remplacez-par-une-cle-tres-longue-et-aleatoire
JWT_EXPIRE=7d

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=VotreMotDePasseSecurise123!

# CORS
ALLOWED_ORIGIN=https://votredomaine.com

# Google reCAPTCHA v2
RECAPTCHA_SECRET=votre_secret_key_recaptcha
